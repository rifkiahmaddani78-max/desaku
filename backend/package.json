{
  "name": "desa-ku-backend",
  "version": "1.0.0",
  "description": "Backend API untuk Sistem Informasi Desa",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/run-migrations.js",
    "seed": "node seeds/run-seeds.js",
    "test:repos": "node tests/repository-test.js",
    "test:auth": "node tests/middleware-test.js",
    "test:all": "npm run test:repos && npm run test:auth",
    "test": "jest --verbose --coverage",
    "test:watch": "jest --watch",
    "test:api": "node tests/api-test.js"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },
  "keywords": [
    "desa",
    "pemerintahan",
    "sistem-informasi"
  ],
  "author": "Developer Desa Ku",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}
